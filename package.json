{
  "name": "@hazeliscoding/kawaii-ui",
  "version": "0.1.0",
  "description": "A kawaii Y2K web component library built with Lit. Works in Angular, HTMX, React, Vue, or plain HTML.",
  "license": "MIT",
  "author": "hazeliscoding",
  "repository": {
    "type": "git",
    "url": "https://github.com/hazeliscoding/kawaii-ui.git"
  },
  "homepage": "https://github.com/hazeliscoding/kawaii-ui#readme",
  "bugs": {
    "url": "https://github.com/hazeliscoding/kawaii-ui/issues"
  },
  "keywords": [
    "web-components",
    "custom-elements",
    "lit",
    "design-system",
    "kawaii",
    "y2k",
    "ui",
    "components",
    "angular",
    "htmx"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/components/button/index.d.ts",
      "import": "./dist/components/button/index.js"
    },
    "./badge": {
      "types": "./dist/components/badge/index.d.ts",
      "import": "./dist/components/badge/index.js"
    },
    "./avatar": {
      "types": "./dist/components/avatar/index.d.ts",
      "import": "./dist/components/avatar/index.js"
    },
    "./card": {
      "types": "./dist/components/card/index.d.ts",
      "import": "./dist/components/card/index.js"
    },
    "./input": {
      "types": "./dist/components/input/index.d.ts",
      "import": "./dist/components/input/index.js"
    },
    "./theme-toggle": {
      "types": "./dist/components/theme-toggle/index.d.ts",
      "import": "./dist/components/theme-toggle/index.js"
    },
    "./modal": {
      "types": "./dist/components/modal/index.d.ts",
      "import": "./dist/components/modal/index.js"
    },
    "./compat-ring": {
      "types": "./dist/components/compat-ring/index.d.ts",
      "import": "./dist/components/compat-ring/index.js"
    },
    "./styles/tokens.css": "./dist/styles/tokens.css",
    "./styles/base.css": "./dist/styles/base.css",
    "./styles/animations.css": "./dist/styles/animations.css",
    "./styles/utilities.css": "./dist/styles/utilities.css",
    "./styles/all.css": "./dist/styles/all.css",
    "./custom-elements.json": "./dist/custom-elements.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css",
    "./src/**/*.ts",
    "./dist/components/**/*.js",
    "./dist/index.js"
  ],
  "scripts": {
    "dev": "vite --mode demo",
    "demo:build": "vite build --mode demo",
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.build.json && npm run build:manifest",
    "build:manifest": "cem analyze --litelement --globs 'src/components/**/*.ts' --outdir dist",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.{ts,css}' '*.{json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,css}' '*.{json,md}'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lit": "^3.2.1"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.4",
    "@open-wc/testing-helpers": "^3.0.1",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.18.1",
    "@typescript-eslint/parser": "^8.18.1",
    "eslint": "^9.17.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "customElements": "dist/custom-elements.json"
}
